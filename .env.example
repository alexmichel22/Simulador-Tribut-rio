# ==============================================
# SIMULADOR TRIBUTÁRIO — VARIÁVEIS DE AMBIENTE
# ==============================================
# Copie este arquivo para .env.local e preencha

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/simulador_tributario"

# Anthropic Claude API (para geração de pareceres)
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth (para autenticação futura)
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"
